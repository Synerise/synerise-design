{
    "targetDefaults": {
        "build": {
            "cache": true,
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "{projectRoot}/dist",
                "{projectRoot}/src/icons",
                "{projectRoot}/src/defaultAvatars"
            ],
            "inputs": [
                "production",
                "^production",
                "{workspaceRoot}/vite.config.base.ts",
                "{workspaceRoot}/scripts/vite/**",
                "{workspaceRoot}/config/typescript/**"
            ]
        },
        "test": {
            "cache": true,
            "dependsOn": [
                "^test"
            ],
            "inputs": [
                "default",
                "{workspaceRoot}/config/jest/**"
            ]
        },
        "types": {
            "cache": true,
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "production",
                "^production",
                "{workspaceRoot}/config/typescript/**"
            ]
        },
        "lint": {
            "cache": true,
            "dependsOn": [],
            "inputs": [
                "default",
                "{workspaceRoot}/eslint.config.mjs"
            ]
        }
    },
    "namedInputs": {
        "default": [
            "{projectRoot}/**/*",
            "sharedGlobals"
        ],
        "production": [
            "default",
            "!{projectRoot}/jest.config.ts"
        ],
        "sharedGlobals": [
            "{workspaceRoot}/package.json",
            "{workspaceRoot}/pnpm-lock.yaml",
            "{workspaceRoot}/pnpm-workspace.yaml",
            "{workspaceRoot}/vite.config.base.ts",
            "{workspaceRoot}/.gitignore"
        ]
    }
}